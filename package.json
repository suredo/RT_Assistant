{
  "name": "rt-assistant",
  "version": "1.0.0",
  "description": "WhatsApp AI assistant for hemodialysis clinic head nurse",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node --watch src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.js",
    "repl": "ts-node scripts/repl.ts",
    "repl:team": "cross-env REPL_ROLE=team ts-node scripts/repl.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/tests/e2e/"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "better-sqlite3": "^12.9.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
