GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
CLAUDE_API_KEY=
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
# RT's number — only this number gets full access (queries, status, management)
RT_NUMBER=
# RT's WhatsApp LID — set this if the bot logs "não autorizado" for the RT number.
# Copy the value after "from:" in the warning log (e.g. 262538902147114)
RT_LID=
# Comma-separated team numbers — restricted to adding demands only (e.g. 5563888888888,5563777777777)
TEAM_NUMBERS=
# Comma-separated team LIDs — use if team members also trigger "não autorizado" warnings
TEAM_LIDS=
# Optional: set to the assistant's number (e.g. 5563999999999) to link via pairing code instead of QR
PAIRING_NUMBER=
NODE_ENV=development
